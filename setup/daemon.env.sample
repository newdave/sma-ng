# SMA Daemon Environment Variables
# Copy to /opt/sma/config/daemon.env and modify as needed

# API key for webhook authentication (recommended for production)
#SMA_DAEMON_API_KEY=your_secret_key_here

# PostgreSQL connection URL for distributed multi-node operation.
# When set, SQLite (--db) is ignored and all nodes share this database.
# Format: postgresql://user:password@host:port/dbname
#SMA_DAEMON_DB_URL=postgresql://sma:password@localhost:5432/sma

# Directory containing ffmpeg and ffprobe binaries (prepended to PATH).
# Omit if ffmpeg/ffprobe are already on the system PATH.
#SMA_DAEMON_FFMPEG_DIR=/usr/local/bin

# Override default config file location
SMA_CONFIG=/opt/sma/config/autoProcess.ini

# Additional environment variables for FFmpeg
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
