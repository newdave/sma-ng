# SMA-NG Daemon Environment File
# Copy to /opt/sma/config/daemon.env and uncomment/modify as needed.
# Loaded by the sma-daemon systemd unit via EnvironmentFile.

# ── daemon listen address ──────────────────────────────────────────────────────
# Stable cluster node identifier. For deployments managed via setup/.local.ini,
# config:roll stamps this automatically from the host's SMA_NODE_NAME value.
#SMA_NODE_NAME=sma-node-a

SMA_DAEMON_HOST=0.0.0.0
SMA_DAEMON_PORT=8585
SMA_DAEMON_WORKERS=2

# ── authentication ─────────────────────────────────────────────────────────────
# Choose ONE method, or leave all commented out for auth-less operation.
#
# Auth-less is appropriate when the daemon is behind a reverse proxy
# (e.g. Nginx, Caddy, Traefik) that enforces its own authentication.
#
# Option 1: API key (recommended for direct exposure)
#   Sent as:  X-API-Key: <key>  or  Authorization: Bearer <key>
#SMA_DAEMON_API_KEY=your_secret_key_here
#
# Option 2: HTTP Basic Auth
#   Sent as:  Authorization: Basic base64(user:pass)
#SMA_DAEMON_USERNAME=sma
#SMA_DAEMON_PASSWORD=your_password_here

# ── database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection — use either the full URL or individual components.
# Priority: SMA_DAEMON_DB_URL > SMA_DAEMON_DB_HOST components > daemon.json db_url
#
# Bundled PostgreSQL profiles (`software-pg`, `intel-pg`, `nvidia-pg`):
# 1) set POSTGRES_* for the postgres container
# 2) set SMA_DAEMON_DB_URL to the matching in-cluster URL
#
#POSTGRES_USER=sma
#POSTGRES_DB=sma
#POSTGRES_PASSWORD=change-me-now
#SMA_DAEMON_DB_URL=postgresql://sma:change-me-now@sma-pgsql:5432/sma
#
# External PostgreSQL / non-`-pg` profiles:
#SMA_DAEMON_DB_URL=postgresql://sma:password@db-host:5432/sma
#
# Advanced alternative: individual components (SMA_DAEMON_DB_HOST is required)
#SMA_DAEMON_DB_HOST=localhost
#SMA_DAEMON_DB_PORT=5432
#SMA_DAEMON_DB_USER=sma
#SMA_DAEMON_DB_PASSWORD=password
#SMA_DAEMON_DB_NAME=sma

# ── paths ──────────────────────────────────────────────────────────────────────
# Default autoProcess.ini location.
SMA_CONFIG=/config/autoProcess.ini

# Default daemon.json location.
SMA_DAEMON_CONFIG=/config/daemon.json

# Default logs directory inside the container.
SMA_DAEMON_LOGS_DIR=/logs

# Directory containing ffmpeg and ffprobe binaries.
# Omit if ffmpeg/ffprobe are already on PATH.
#SMA_DAEMON_FFMPEG_DIR=/usr/local/bin

# Override FFmpeg/FFprobe paths explicitly if needed.
#SMA_FFMPEG=/usr/local/bin/ffmpeg
#SMA_FFPROBE=/usr/local/bin/ffprobe

# ── Intel QSV / VAAPI (intel and intel-pg profiles only) ───────────────────────
# Select the Intel VAAPI userspace driver inside the container if auto-detect
# picks the wrong one.
#LIBVA_DRIVER_NAME=iHD
#
# GID of the host's 'render' group — required for /dev/dri/renderD128 access.
# Find it with:  getent group render
# This must be set; the default of 992 may differ on your host.
#RENDER_GID=992

# ── NVIDIA (nvidia and nvidia-pg profiles only) ───────────────────────────────
#NVIDIA_VISIBLE_DEVICES=all
#NVIDIA_DRIVER_CAPABILITIES=video,compute,utility
