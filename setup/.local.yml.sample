# setup/.local.yml.sample — per-machine deployment configuration template
#
# Copy this file to setup/.local.yml and customise it.
# setup/.local.yml is gitignored and never committed.
#
# Resolution order for each key:
#   hosts.<name>.<key>  >  deploy.<key>  >  built-in default
#
# deploy.hosts is a list of logical host labels.
# Each label must have a matching entry under the top-level hosts: section
# that provides at minimum an address: (IP or hostname) and user: (SSH user).
# Any key from deploy: can be overridden per-host in that entry.

# ── deploy — project-wide defaults and host list ─────────────────────────────

deploy:
  # Logical labels for each remote host. These must match keys under hosts:.
  hosts:
    - sma-node1
    - sma-node2

  # Use sudo on the remote host for docker and system commands.
  use_sudo: false

  # Remote directory to sync into.
  deploy_dir: /opt/sma

  # SSH port (can be overridden per-host).
  ssh_port: 22

  # SSH key to use (can be overridden per-host).
  # ssh_key: ~/.ssh/id_ed25519_sma

  # Default ffmpeg/ffprobe directory on remote hosts.
  # ffmpeg_dir: /usr/local/bin

  # Virtualenv management on remote hosts.
  # auto_create_venv: true            # recreate venv if missing/unhealthy
  # venv_dir: venv                    # path is relative to deploy_dir
  # python_bin: /usr/bin/python3      # interpreter used to build the venv

  # Database connection details (for external PostgreSQL).
  # db_host: "db.example.com"
  # db_port: 5432
  # db_user: sma
  # db_password: ""
  # db_name: sma
  # db_url: ""                        # full URL; overrides the components above

  # Docker Compose profile to use (e.g. intel, nvenc, intel-pg).
  # docker_profile: intel

  # Directory containing docker-compose.yml (defaults to deploy_dir/docker).
  # docker_compose_dir: /opt/sma/docker

  # GitHub user / token for GHCR image access (auto-detected from 'gh' CLI if omitted).
  # gh_user: myuser
  # gh_token: ""

# ── per-host entries ──────────────────────────────────────────────────────────
# One entry per label in deploy.hosts.
# address: and user: are required for SSH — all other keys are optional overrides.
# Any key from deploy: can be overridden here.

hosts:
  sma-node1:
    address: 192.168.1.10    # IP or hostname to SSH to
    user: deploy             # SSH user on the remote host
    docker_profile: intel-pg # override deploy.docker_profile for this host
    ffmpeg_dir: /usr/local/bin

  sma-node2:
    address: 192.168.1.11
    user: deploy
    docker_profile: intel
    ffmpeg_dir: /usr/local/bin

# ── daemon configuration ──────────────────────────────────────────────────────
# Stamped into config/sma-ng.yml (daemon block, kebab-case) and
# config/daemon.env by `mise run config:roll`. These are global — not per-host.

daemon:
  # API key for protecting daemon endpoints (SMA_DAEMON_API_KEY).
  # api_key: ""

  # PostgreSQL connection URL — derived from deploy db_* keys if not set.
  # Ignored when the host's docker_profile ends in `-pg` (bundled postgres).
  # db_url: ""

  # ffmpeg/ffprobe directory (SMA_DAEMON_FFMPEG_DIR). Overrides deploy.ffmpeg_dir.
  # ffmpeg_dir: ""

# ── services ─────────────────────────────────────────────────────────────────
# Mirrors the `services:` block in sma-ng.yml exactly:
#   services.<type>.<instance>.<field>
# where <type> is one of sonarr, radarr, plex, jellyfin, emby and <instance>
# is any name you choose (e.g. main, kids, 4k).
#
# `mise run config:roll` stamps each instance into sma-ng.yml under
# `services.<type>.<instance>` and rebuilds `daemon.routing` from every
# instance that defines both `path:` and `profile:`. The `path` and
# `profile` keys live here only so routing can be derived; they are not
# copied into the service block.

# services:
#   sonarr:
#     main:
#       url: http://sonarr.example.com:8989
#       apikey: ""
#       path: /media/tv
#       profile: rq
#     kids:
#       url: http://sonarr.example.com:8990
#       apikey: ""
#       path: /media/tv/Kids
#       profile: lq
#
#   radarr:
#     main:
#       url: http://radarr.example.com:7878
#       apikey: ""
#       path: /media/movies
#       profile: rq
#
#   plex:
#     main:
#       url: http://plex.example.com:32400
#       token: ""
#       username: ""
#       servername: ""
#
#   jellyfin:
#     main:
#       url: ""
#       token: ""
#
#   emby:
#     main:
#       url: ""
#       apikey: ""

# ── base overrides ───────────────────────────────────────────────────────────
# Deep-merged into config/sma-ng.yml `base:` on every `mise run config:roll`.
# Use this to lock per-deployment defaults — for example, force every host
# to use Intel QSV and encode HEVC by default:
#
# base:
#   video:
#     gpu: qsv
#     codec:
#       - hevc
#
# The merge is recursive for dicts; lists and scalars overwrite. Anything
# you do not list here is inherited from setup/sma-ng.yml.sample.
