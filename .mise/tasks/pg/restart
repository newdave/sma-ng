#!/usr/bin/env bash
#MISE description="Restart bundled PostgreSQL containers on DEPLOY_HOSTS running *-pg profiles"
#MISE aliases=["deploy:docker:pg:restart"]
#MISE depends=["deploy:mise"]
set -euo pipefail

# shellcheck disable=SC1091
# lib.sh is sourced relative to this script's directory at runtime.
source "$(dirname "$0")/../../shared/deploy/lib.sh"

ALL_HOSTS=$(lc deploy hosts "")
DEPLOY_HOSTS="${HOST:-$ALL_HOSTS}"
PG_HEALTH_TIMEOUT=${PG_HEALTH_TIMEOUT:-120}

failed=""
matched=0

for host in $DEPLOY_HOSTS; do
    init_docker_host_context "$host"

    if [ -z "$profile" ]; then
        echo "ERROR: [$host] DOCKER_PROFILE is not set in $LOCAL — add it to [deploy] or the host section" >&2
        failed="$failed $host"
        continue
    fi

    if ! docker_profile_is_pg "$profile"; then
        echo "==> [$host] skipping postgres restart (profile: $profile)"
        continue
    fi

    matched=1

    echo ""

    # Drop any stale `sma-postgres`-named container from before the
    # canonical container_name standardized on `sma-pgsql`. Volume
    # sma-pgdata is preserved.
    if ! remove_stale_pg_containers "$host" "sma-pgsql"; then
        echo "  WARNING: [$host] stale-pg cleanup reported errors — continuing" >&2
    fi

    echo "==> [$host] restarting sma-pgsql (profile: $profile)"
    # If a stale container was just removed, no `sma-pgsql` exists yet
    # for compose to restart — fall back to `up -d` so the canonical
    # name is created in place. `up -d` is a no-op when the container
    # is already running and named correctly, so the same path works
    # for the steady-state case after the first run.
    # shellcheck disable=SC2086,SC2029,SC2154  # ssh_opts must word-split for ssh; remote command intentionally expands client-side
    if ssh $ssh_opts "$ssh_target" "${sudo_prefix}docker inspect sma-pgsql >/dev/null 2>&1"; then
        if ! run_remote_compose "$host" "--profile $profile restart sma-pgsql"; then
            echo "ERROR: [$host] docker compose restart failed for sma-pgsql" >&2
            failed="$failed $host"
            continue
        fi
    else
        echo "  no sma-pgsql container present — bringing one up via compose"
        if ! run_remote_compose "$host" "--profile $profile up -d sma-pgsql"; then
            echo "ERROR: [$host] docker compose up failed for sma-pgsql" >&2
            failed="$failed $host"
            continue
        fi
    fi

    echo "==> [$host] waiting for sma-pgsql to become healthy (timeout: ${PG_HEALTH_TIMEOUT}s)"
    if ! wait_for_remote_container_health "$host" "sma-pgsql" "$PG_HEALTH_TIMEOUT"; then
        echo "ERROR: [$host] sma-pgsql did not become healthy within ${PG_HEALTH_TIMEOUT}s" >&2
        failed="$failed $host"
        continue
    fi

    print_remote_container_summary "$host" "sma-pgsql"
    echo "==> [$host] done"
done

if [ "$matched" -eq 0 ]; then
    echo ""
    echo "No hosts are configured with a *-pg DOCKER_PROFILE."
    exit 0
fi

if [ -n "$failed" ]; then
    echo ""
    echo "ERROR: postgres restart failed for:$failed" >&2
    exit 1
fi

echo ""
echo "Bundled PostgreSQL restarted on matching hosts: $DEPLOY_HOSTS"
