#!/usr/bin/env bash
#MISE description="Recreate PostgreSQL for *-pg profile hosts (no-op now that pg profiles use an external database)"
#MISE aliases=["deploy:docker:pg:recreate"]
#MISE depends=["deploy:mise"]
set -euo pipefail

# shellcheck disable=SC1091
# lib.sh is sourced relative to this script's directory at runtime.
source "$(dirname "$0")/../../shared/deploy/lib.sh"

ALL_HOSTS=$(lc deploy hosts "")
if [ -n "${HOSTS:-}" ]; then
  DEPLOY_HOSTS="$HOSTS"
else
  DEPLOY_HOSTS="${HOST:-$ALL_HOSTS}"
fi

if [ -z "$DEPLOY_HOSTS" ]; then
  echo "ERROR: no hosts selected. Set HOST, HOSTS, or deploy.hosts in $LOCAL" >&2
  exit 1
fi

matched=0
for host in $DEPLOY_HOSTS; do
  init_docker_host_context "$host"

  if [ -z "$profile" ]; then
    echo "ERROR: [$host] docker_profile is not set in $LOCAL — add it to [deploy] or the host section" >&2
    continue
  fi

  if ! docker_profile_is_pg "$profile"; then
    echo "==> [$host] skipping postgres recreate (profile: $profile)"
    continue
  fi

  matched=1
  echo "==> [$host] profile $profile expects external PostgreSQL via daemon.db-url — recreate the external instance manually"
done

if [ "$matched" -eq 0 ]; then
  echo ""
  echo "No hosts are configured with a *-pg docker_profile."
fi
