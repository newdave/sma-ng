#!/usr/bin/env bash
#MISE description="Roll config to remote hosts: create missing config/sma-ng.yml, merge in new sample keys, and stamp daemon/service credentials from local.yml"
#MISE aliases=["deploy:config:roll"]
#MISE depends=["deploy:mise"]
set -euo pipefail

# shellcheck disable=SC1091
# lib.sh is sourced relative to this script's directory at runtime.
source "$(dirname "$0")/../../shared/deploy/lib.sh"

ALL_HOSTS=$(lc deploy hosts "")
DEPLOY_HOSTS="${HOST:-$ALL_HOSTS}"

b64enc() { printf '%s' "$1" | base64 | tr -d '\n'; }

mk_ssh_opts() {
    local port="$1" key="$2"
    SSH_OPTS=(-p "$port" -o BatchMode=yes -o StrictHostKeyChecking=accept-new)
    [ -n "$key" ] && SSH_OPTS+=(-i "$(eval echo "$key")")
}

ensure_remote_config() {
    local host="$1" remote_path="$2" sample_path="$3"
    # shellcheck disable=SC2029,SC2154  # $remote_path expands client-side; ssh_target/SSH_OPTS/sudo_prefix are set in the outer loop
    if ssh "${SSH_OPTS[@]}" "$ssh_target" "test -f $remote_path" 2>/dev/null; then
        echo "  exists: $(basename "$remote_path")"
    else
        echo "  creating: $(basename "$remote_path")"
        # shellcheck disable=SC2029  # $sudo_prefix, $sample_path, $remote_path expand client-side (intentional)
        ssh "${SSH_OPTS[@]}" "$ssh_target" "${sudo_prefix}cp $sample_path $remote_path"
    fi
}

# Detect GPU on a remote host; echoes one of: nvenc qsv vaapi videotoolbox software
detect_remote_gpu() {
    local host="$1"
    # shellcheck disable=SC2087  # heredoc body stays literal until the remote shell runs it
    ssh "${SSH_OPTS[@]}" "$ssh_target" 'bash -s' <<'REMOTE'
    if command -v nvidia-smi >/dev/null 2>&1 && nvidia-smi >/dev/null 2>&1; then
      echo nvenc
    elif command -v vainfo >/dev/null 2>&1 && vainfo 2>&1 | grep -qi intel; then
      echo qsv
    elif [ -e /dev/dri/renderD128 ] && command -v vainfo >/dev/null 2>&1 && vainfo >/dev/null 2>&1; then
      echo vaapi
    else
      echo software
    fi
REMOTE
}

# Pull each *.yaml/*.yml from the host, merge in any new keys from the
# upstream sample, and push the result back.
sync_yaml_keys() {
    local host="$1" dir="$2" tmpdir="$3"

    echo "  checking for new keys in sma-ng.yml.sample..."

    # shellcheck disable=SC2086
    rsync -az -e "ssh ${SSH_OPTS[*]}" \
        "$ssh_target:$dir/config/" "$tmpdir/remote/" \
        --include='*.yaml' --include='*.yml' --exclude='*' 2>/dev/null || true

    local changed_files=()
    for remote_yaml in "$tmpdir"/remote/*.yaml "$tmpdir"/remote/*.yml; do
        [ -f "$remote_yaml" ] || continue
        local basename
        basename=$(basename "$remote_yaml")
        echo "  merging into $basename..."
        python3 yaml_merge.py \
            "$remote_yaml" "setup/sma-ng.yml.sample" \
            --additions --sort --deprecate
        changed_files+=("$remote_yaml")
    done

    if [ "${#changed_files[@]}" -gt 0 ]; then
        echo "  pushing updated configs to $ssh_target:$dir/config/"
        # shellcheck disable=SC2086
        rsync -az -e "ssh ${SSH_OPTS[*]}" \
            "$tmpdir/remote/" "$ssh_target:$dir/config/" \
            --include='*.yaml' --include='*.yml' --exclude='*'
    fi
}

stamp_ffmpeg_paths() {
    local host="$1" dir="$2" ffmpeg_dir="$3" use_sudo="${4:-false}"
    if [ -z "$ffmpeg_dir" ]; then
        return
    fi
    echo "  setting ffmpeg/ffprobe paths to $ffmpeg_dir in sma-ng.yml"
    # shellcheck disable=SC2029  # $dir, $ffmpeg_dir, $use_sudo expand client-side (intentional)
    ssh "${SSH_OPTS[@]}" "$ssh_target" \
        "python3 $dir/.mise/shared/deploy/lib/stamp_ffmpeg.py $dir $ffmpeg_dir $use_sudo"
}

stamp_daemon_config() {
    local host="$1" dir="$2" daemon_api_key="$3" daemon_db_url="$4" \
        daemon_ffmpeg_dir="$5" daemon_node_name="$6" services_json="$7" \
        daemon_db_user="${8:-}" daemon_db_pw="${9:-}" daemon_db_name="${10:-}" \
        base_json="${11:-{\}}" profiles_json="${12:-{\}}"

    if [ -z "$daemon_api_key" ] && [ -z "$daemon_db_url" ] && \
       [ -z "$daemon_ffmpeg_dir" ] && [ -z "$daemon_node_name" ] && [ "$services_json" = "{}" ] && \
       [ -z "$daemon_db_user" ] && [ -z "$daemon_db_pw" ] && [ -z "$daemon_db_name" ] && \
       [ "$base_json" = "{}" ] && [ "$profiles_json" = "{}" ]; then
        echo "  no daemon, services, base, or profiles overrides configured in $LOCAL, skipping"
        return
    fi

    echo "  stamping daemon + service + base + profiles overrides into config/sma-ng.yml and config/daemon.env"
    local _api_b64 _db_url_b64 _ffmpeg_b64 _node_name_b64 _dbuser_b64 _dbpw_b64 _dbname_b64 _svc_b64 _base_b64 _prof_b64
    _api_b64=$(b64enc "$daemon_api_key")
    _db_url_b64=$(b64enc "$daemon_db_url")
    _ffmpeg_b64=$(b64enc "$daemon_ffmpeg_dir")
    _node_name_b64=$(b64enc "$daemon_node_name")
    _dbuser_b64=$(b64enc "$daemon_db_user")
    _dbpw_b64=$(b64enc "$daemon_db_pw")
    _dbname_b64=$(b64enc "$daemon_db_name")
    _svc_b64=$(b64enc "$services_json")
    _base_b64=$(b64enc "$base_json")
    _prof_b64=$(b64enc "$profiles_json")
    # shellcheck disable=SC2029  # $dir and b64-encoded args expand client-side (intentional)
    ssh "${SSH_OPTS[@]}" "$ssh_target" \
        "python3 $dir/.mise/shared/deploy/lib/stamp_daemon.py $dir $_api_b64 $_db_url_b64 $_ffmpeg_b64 $_node_name_b64 $_dbuser_b64 $_dbpw_b64 $_dbname_b64 $_svc_b64 $_base_b64 $_prof_b64"
}

# Copy and stamp post-process scripts; also update shebangs in root entry points.
deploy_post_process() {
    local host="$1" dir="$2" plex_token="$3" plex_username="$4" \
        plex_servername="$5" jellyfin_url="$6" jellyfin_token="$7" \
        emby_url="$8" emby_apikey="$9"

    echo "  deploying post-process scripts from setup/post_process/ to post_process/"
    local _plex_token_b64 _plex_user_b64 _plex_srv_b64
    local _jf_url_b64 _jf_token_b64 _emby_url_b64 _emby_key_b64
    _plex_token_b64=$(b64enc "$plex_token")
    _plex_user_b64=$(b64enc "$plex_username")
    _plex_srv_b64=$(b64enc "$plex_servername")
    _jf_url_b64=$(b64enc "$jellyfin_url")
    _jf_token_b64=$(b64enc "$jellyfin_token")
    _emby_url_b64=$(b64enc "$emby_url")
    _emby_key_b64=$(b64enc "$emby_apikey")
    # shellcheck disable=SC2029  # $dir and b64-encoded args expand client-side (intentional)
    ssh "${SSH_OPTS[@]}" "$ssh_target" \
        "python3 $dir/.mise/shared/deploy/lib/stamp_postprocess.py $dir $_plex_token_b64 $_plex_user_b64 $_plex_srv_b64 $_jf_url_b64 $_jf_token_b64 $_emby_url_b64 $_emby_key_b64"
}

# ── Main per-host loop ───────────────────────────────────────────────────────

for host in $DEPLOY_HOSTS; do
    cfg="$CFG $LOCAL $host"
    dir=$($cfg deploy_dir ~/sma)
    port=$($cfg ssh_port 22)
    key=$($cfg ssh_key "")
    use_sudo=$($cfg use_sudo "false")
    ffmpeg_dir=$($cfg ffmpeg_dir "")
    remote_user=$($cfg user "$(whoami)")
    remote_address=$($cfg address "")
    ssh_target="${remote_user}@${remote_address}"

    mk_ssh_opts "$port" "$key"

    sudo_prefix=""
    [ "$use_sudo" = "true" ] && sudo_prefix="sudo "

    services_json=$(python3 scripts/services-json.py "$LOCAL")
    base_overrides_json=$(python3 scripts/local-section-json.py "$LOCAL" base)
    profiles_overrides_json=$(python3 scripts/local-section-json.py "$LOCAL" profiles)

    echo ""
    echo "==> [$host] rolling config in $dir/config"

    gpu=$(detect_remote_gpu "$host")
    echo "  GPU: $gpu"

    echo "  checking for missing config files..."
    # shellcheck disable=SC2029,SC2087  # sudo_prefix/dir/gpu expand locally; heredoc body stays literal until the remote shell runs it.
    ssh "${SSH_OPTS[@]}" "$ssh_target" "${sudo_prefix}bash -s" "$dir" "$gpu" <<'REMOTE'
    dir="$1" gpu="$2"
    create_config() {
      local dest="$dir/config/$1" sample="$dir/setup/$2" label="$3"
      if [ -f "$dest" ]; then
        echo "  exists: config/$1"
      else
        cp "$sample" "$dest"
        if [ "$gpu" != "software" ]; then
          sed -i "s/^  gpu:.*/  gpu: $gpu/" "$dest"
        fi
        echo "  created: config/$1 ($label, gpu=$gpu)"
      fi
    }
    create_config sma-ng.yml sma-ng.yml.sample "base config with profiles"
REMOTE
    ensure_remote_config "$host" "$dir/config/sma-ng.yml" "$dir/setup/sma-ng.yml.sample"
    ensure_remote_config "$host" "$dir/config/daemon.env" "$dir/setup/daemon.env.sample"

    _backup_ts=$(date +%Y-%m-%dT%H-%M-%S)
    # shellcheck disable=SC2029  # $dir, $_backup_ts expand client-side (intentional)
    ssh "${SSH_OPTS[@]}" "$ssh_target" \
        "mkdir -p $dir/.backup/$_backup_ts && cp -a $dir/config/. $dir/.backup/$_backup_ts/"

    tmpdir=$(mktemp -d)
    trap 'rm -rf "$tmpdir"' EXIT
    sync_yaml_keys "$host" "$dir" "$tmpdir"

    stamp_ffmpeg_paths "$host" "$dir" "$ffmpeg_dir" "$use_sudo"

    daemon_api_key=$(lc daemon api_key "")
    daemon_ffmpeg_dir=$(lc daemon ffmpeg_dir "")
    daemon_node_name="$host"
    [ -z "$daemon_ffmpeg_dir" ] && daemon_ffmpeg_dir="$ffmpeg_dir"

    docker_profile=$($cfg docker_profile "")
    daemon_db_url=""
    daemon_db_user=""
    daemon_db_pw=""
    daemon_db_name=""

    if [[ "$docker_profile" == *-pg ]]; then
        daemon_db_user=$($cfg db_user "sma")
        daemon_db_pw=$($cfg db_password "")
        daemon_db_name=$($cfg db_name "sma")
    else
        daemon_db_url=$(lc daemon db_url "")
        if [ -z "$daemon_db_url" ]; then
            _db_host=$($cfg db_host "")
            if [ -n "$_db_host" ]; then
                _db_user=$($cfg db_user "sma")
                _db_pw=$($cfg db_password "")
                _db_port=$($cfg db_port "5432")
                _db_name=$($cfg db_name "sma")
                if [ -n "$_db_pw" ]; then
                    daemon_db_url="postgresql://${_db_user}:${_db_pw}@${_db_host}:${_db_port}/${_db_name}"
                else
                    daemon_db_url="postgresql://${_db_user}@${_db_host}:${_db_port}/${_db_name}"
                fi
            fi
        fi
    fi
    stamp_daemon_config "$host" "$dir" "$daemon_api_key" "$daemon_db_url" "$daemon_ffmpeg_dir" \
        "$daemon_node_name" "$services_json" "$daemon_db_user" "$daemon_db_pw" "$daemon_db_name" \
        "$base_overrides_json" "$profiles_overrides_json"

    plex_token=$(lc plex token "")
    plex_username=$(lc plex username "")
    plex_servername=$(lc plex servername "")
    jellyfin_url=$(lc jellyfin url "")
    jellyfin_token=$(lc jellyfin token "")
    emby_url=$(lc emby url "")
    emby_apikey=$(lc emby apikey "")
    deploy_post_process "$host" "$dir" \
        "$plex_token" "$plex_username" "$plex_servername" \
        "$jellyfin_url" "$jellyfin_token" \
        "$emby_url" "$emby_apikey"

    echo "  done"
done

echo ""
echo "Config roll complete: $DEPLOY_HOSTS"
