#!/usr/bin/env bash
#MISE description="Render the effective resolved config for a profile (--profile, --diff, --section). With --input FILE: print the full FFmpeg command that would run, without transcoding."
set -euo pipefail

cd "${MISE_PROJECT_ROOT:-$(git rev-parse --show-toplevel)}"

if [ -x "venv/bin/python" ]; then
    py="venv/bin/python"
else
    py="python3"
fi

exec "$py" scripts/show-config.py "$@"
