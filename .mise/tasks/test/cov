#!/usr/bin/env bash
#MISE description="Run tests with coverage (HTML + terminal summary)"
#MISE aliases=["dev:test:cov"]
set -euo pipefail

"$PY" -m pytest \
  --cov=resources --cov=converter --cov=autoprocess \
  --cov-report=xml \
  --cov-report=html \
  --cov-report=json:cov.json \
  --cov-report=term-missing:skip-covered \
  --cov-fail-under="${COV_FAIL_UNDER:-90}"
