#!/usr/bin/env bash
#MISE description="Sync code to remote hosts, pull latest Docker image, and recreate SMA containers on all DEPLOY_HOSTS"
#MISE aliases=["deploy:docker:upgrade"]
#MISE depends=["deploy:mise"]
set -euo pipefail

# shellcheck disable=SC1091
# lib.sh is sourced relative to this script's directory at runtime.
source "$(dirname "$0")/../../shared/deploy/lib.sh"

ALL_HOSTS=$(lc deploy hosts "")
DEPLOY_HOSTS="${HOST:-$ALL_HOSTS}"

HEALTH_TIMEOUT=${HEALTH_TIMEOUT:-120}

failed=""
for host in $DEPLOY_HOSTS; do
    cfg="$CFG $LOCAL $host"
    init_docker_host_context "$host"
    rsync_extra=$($cfg rsync_extra "")
    daemon_port=$($cfg daemon_port 8585)
    daemon_api_key=$($cfg daemon_api_key "")

    if [ -z "$profile" ]; then
        echo "ERROR: [$host] docker_profile is not set in $LOCAL — add it to [deploy] or the host section" >&2
        failed="$failed $host"
        continue
    fi

    service="sma-${profile}"

    echo ""
    echo "==> [$host] upgrading $service (profile: $profile)"

    if ! sync_codebase_to_host "$host" "$rsync_extra"; then
        echo "ERROR: [$host] rsync failed" >&2
        failed="$failed $host"
        continue
    fi

    # Make sure the bind-mount targets exist before stamping daemon.env or
    # bringing the container up. Otherwise `install` below fails with
    # "No such file or directory" on a fresh host, and docker compose
    # would create the volume dirs root-owned.
    if ! ensure_remote_install_dirs "$host"; then
        echo "ERROR: [$host] could not create install dirs" >&2
        failed="$failed $host"
        continue
    fi

    # Pin the cluster identity into daemon.env before recreating the
    # container. Without this, a host whose daemon.env was seeded but never
    # passed through config:roll comes up with no SMA_NODE_NAME, the daemon
    # generates a fresh UUID, and the previously-approved node row gets
    # replaced by a new pending one on every redeploy.
    if ! ensure_remote_node_name "$host"; then
        echo "ERROR: [$host] could not stamp SMA_NODE_NAME into daemon.env" >&2
        failed="$failed $host"
        continue
    fi

    # Make sure Docker itself is on the host before any compose call.
    if ! ensure_remote_docker "$host"; then
        echo "ERROR: [$host] Docker installation failed — aborting" >&2
        failed="$failed $host"
        continue
    fi

    # Pull the latest image for this profile
    echo "==> [$host] pulling latest image"
    if ! run_remote_compose "$host" "--profile $profile pull"; then
        echo "ERROR: [$host] docker compose pull failed" >&2
        failed="$failed $host"
        continue
    fi

    # On *-pg profiles, ensure the bundled postgres is up before
    # recreating the SMA service. Plain `up -d` (no --force-recreate)
    # is a no-op when sma-pgsql is already running and healthy, but
    # creates the container on a fresh host. Without this, the SMA
    # container starts without its database and fails its health check.
    if docker_profile_is_pg "$profile"; then
        # Drop any old `sma-postgres`-named container left over from
        # before the canonical container_name standardized on
        # `sma-pgsql`. Volume sma-pgdata is preserved so the new
        # container starts on the same data.
        if ! remove_stale_pg_containers "$host" "sma-pgsql"; then
            echo "  WARNING: [$host] stale-pg cleanup reported errors — continuing" >&2
        fi
        echo "==> [$host] ensuring sma-pgsql is up (profile: $profile)"
        if ! run_remote_compose "$host" "--profile $profile up -d sma-pgsql"; then
            echo "ERROR: [$host] docker compose up failed for sma-pgsql" >&2
            failed="$failed $host"
            continue
        fi
        if ! wait_for_remote_container_health "$host" "sma-pgsql" "${HEALTH_TIMEOUT}"; then
            echo "  WARNING: [$host] sma-pgsql did not become healthy within ${HEALTH_TIMEOUT}s — continuing anyway" >&2
        fi
    fi

    # Drop any stale SMA daemon container left over from a previous
    # profile choice on this host (e.g. switching `intel` -> `intel-pg`
    # leaves `sma-ng-intel` running and grabs port 8585, so compose's
    # --force-recreate of `sma-ng-intel-pg` fails with a port-bind
    # error). Only SMA-owned container_names from docker-compose.yml
    # are touched; the bundled sma-pgsql is preserved.
    if ! remove_stale_sma_containers "$host" "$service"; then
        echo "  WARNING: [$host] stale-container cleanup reported errors — continuing" >&2
    fi

    # Recreate only the SMA service — leave postgres untouched
    echo "==> [$host] recreating $service"
    if ! run_remote_compose "$host" "--profile $profile up -d --force-recreate --no-deps $service"; then
        echo "ERROR: [$host] docker compose up failed" >&2
        failed="$failed $host"
        continue
    fi

    # Poll the health endpoint until the daemon is ready
    echo "==> [$host] waiting for $service to become healthy (timeout: ${HEALTH_TIMEOUT}s)"
    if [ -n "$daemon_api_key" ]; then
        health_cmd="curl -sf -H 'X-API-Key: ${daemon_api_key}' http://127.0.0.1:${daemon_port}/health"
    else
        health_cmd="curl -sf http://127.0.0.1:${daemon_port}/health"
    fi

    elapsed=0
    timed_out=false
    while ! run_remote_command "$host" "$health_cmd" >/dev/null 2>&1; do
        if [ "$elapsed" -ge "$HEALTH_TIMEOUT" ]; then
            timed_out=true
            break
        fi
        sleep 5
        elapsed=$((elapsed + 5))
    done

    if [ "$timed_out" = "true" ]; then
        echo "  WARNING: [$host] $service did not become healthy within ${HEALTH_TIMEOUT}s — check logs" >&2
    else
        echo "==> [$host] $service healthy (${elapsed}s)"
    fi

    # Print running container summary
    print_remote_container_summary "$host" "$service"

    echo "==> [$host] done"
done

if [ -n "$failed" ]; then
    echo ""
    echo "ERROR: docker upgrade failed for:$failed" >&2
    exit 1
fi

echo ""
echo "Docker upgrade complete: $DEPLOY_HOSTS"
