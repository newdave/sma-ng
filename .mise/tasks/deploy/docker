#!/usr/bin/env bash
#MISE description="Push docker/docker-compose.yml to each host, pull the latest image, then `docker compose down` + `up -d --force-recreate`"
#MISE aliases=["deploy:docker:upgrade"]
#MISE depends=["deploy:check"]
set -euo pipefail

# shellcheck disable=SC1091
source "$(dirname "$0")/../../shared/deploy/lib.sh"

ALL_HOSTS=$(lc deploy hosts "")
if [ -n "${HOSTS:-}" ]; then
  DEPLOY_HOSTS="$HOSTS"
else
  DEPLOY_HOSTS="${HOST:-$ALL_HOSTS}"
fi

if [ -z "$DEPLOY_HOSTS" ]; then
  echo "ERROR: no hosts selected. Set HOST, HOSTS, or deploy.hosts in $LOCAL" >&2
  exit 1
fi

HEALTH_TIMEOUT=${HEALTH_TIMEOUT:-120}

failed=""
for host in $DEPLOY_HOSTS; do
  init_docker_host_context "$host"
  # shellcheck disable=SC2154  # cfg/profile/ssh_opts/ssh_target/sudo_prefix populated by init_docker_host_context
  daemon_port=$($cfg daemon_port 8585)
  daemon_api_key=$($cfg daemon_api_key "")

  if [ -z "$profile" ]; then
    echo "ERROR: [$host] docker_profile is not set in $LOCAL — add it to [deploy] or the host section" >&2
    failed="$failed $host"
    continue
  fi

  service="sma-${profile}"

  echo ""
  echo "==> [$host] redeploying $service (profile: $profile)"

  # Make sure the bind-mount targets exist before bringing the container up.
  if ! ensure_remote_install_dirs "$host"; then
    echo "ERROR: [$host] could not create install dirs" >&2
    failed="$failed $host"
    continue
  fi

  if ! ensure_remote_docker "$host"; then
    echo "ERROR: [$host] Docker installation failed — aborting" >&2
    failed="$failed $host"
    continue
  fi

  # Minimal payload: just docker/docker-compose.yml. The daemon code lives
  # inside the image; .mise/ control-plane scripts only need to be on disk
  # when deploy:setup runs initial provisioning.
  echo "==> [$host] syncing docker/docker-compose.yml"
  # shellcheck disable=SC2086,SC2154  # ssh_opts must word-split; ssh_target/dir set by init_docker_host_context
  if ! rsync -az -e "ssh $ssh_opts" \
    docker/docker-compose.yml \
    "$ssh_target:$dir/docker/docker-compose.yml"; then
    echo "ERROR: [$host] rsync of docker-compose.yml failed" >&2
    failed="$failed $host"
    continue
  fi
  chown_remote_path_to_ssh_user "$host" "$dir/docker/docker-compose.yml"

  # ── Fast-path detection ────────────────────────────────────────────
  # Compare the registry's current manifest digest against the digest of
  # the image actually backing the running sma-ng container. When they
  # match, the heavy `pull → down → up --force-recreate` cycle is
  # unnecessary — the only thing that needs to take effect is whatever
  # config / compose changes just landed. `compose restart` re-launches
  # the entrypoint inside the existing container, which is enough for
  # bind-mounted sma-ng.yml refreshes (deploy:remote ran deploy:config
  # immediately before this task).
  #
  # FORCE_RECREATE=1 disables the fast-path so an operator can always
  # opt back into a full recreate (e.g. to clear in-container state).
  fast_path="no"
  if [ "${FORCE_RECREATE:-0}" != "1" ]; then
    if image_ref=$(resolve_image_ref 2>/dev/null) && [ -n "$image_ref" ]; then
      image_repo="${image_ref%:*}"
      registry_digest=$(registry_manifest_digest "$image_ref" || true)
      running_digest=$(running_container_image_digest "$host" "sma-ng" "$image_repo" || true)
      if [ -n "$registry_digest" ] && [ -n "$running_digest" ] && [ "$registry_digest" = "$running_digest" ]; then
        fast_path="yes"
        echo "==> [$host] image already current ($registry_digest); skipping pull + recreate, restarting only"
      elif [ -n "$registry_digest" ] && [ -n "$running_digest" ]; then
        echo "==> [$host] registry image differs from running ($registry_digest vs $running_digest); will pull + recreate"
      else
        echo "  NOTE: [$host] could not compare image digests (registry='${registry_digest:-?}' running='${running_digest:-?}'); will pull + recreate"
      fi
    fi
  fi

  if docker_profile_is_pg "$profile"; then
    echo "==> [$host] profile $profile expects external PostgreSQL in daemon.db-url"
  fi

  if [ "$fast_path" = "yes" ]; then
    # Config-only path. Compose restart re-execs the entrypoint inside
    # the existing container so the bind-mounted sma-ng.yml is re-read
    # without losing the cached image layers. ~3-5s vs ~30s for a full
    # down/up/recreate cycle.
    echo "==> [$host] restarting $service (config-only path)"
    if ! run_remote_compose "$host" "--profile $profile restart $service"; then
      echo "ERROR: [$host] docker compose restart $service failed" >&2
      failed="$failed $host"
      continue
    fi
  else
    echo "==> [$host] pulling latest image"
    if ! run_remote_compose "$host" "--profile $profile pull"; then
      echo "ERROR: [$host] docker compose pull failed" >&2
      failed="$failed $host"
      continue
    fi

    # One-time migration: drop legacy per-profile container names.
    if ! remove_stale_sma_containers "$host"; then
      echo "  WARNING: [$host] stale-container cleanup reported errors — continuing" >&2
    fi

    echo "==> [$host] stopping $service"
    if ! run_remote_compose "$host" "--profile $profile down --remove-orphans"; then
      echo "  WARNING: [$host] docker compose down reported errors — continuing" >&2
    fi

    # `compose down` only stops containers belonging to the active profile.
    # If the canonical `sma-ng` container was last brought up under a
    # different profile (e.g. switching from intel-pg to intel), it survives
    # `down` and then collides with `up`'s container_name. Force-remove by
    # name as a belt-and-suspenders sweep before recreating.
    # shellcheck disable=SC2154  # sudo_prefix populated by init_docker_host_context
    if ! run_remote_command "$host" "${sudo_prefix}docker rm -f sma-ng >/dev/null 2>&1 || true"; then
      echo "  WARNING: [$host] could not force-remove pre-existing sma-ng container" >&2
    fi

    echo "==> [$host] starting $service (--force-recreate)"
    if ! run_remote_compose "$host" "--profile $profile up -d --force-recreate --no-deps $service"; then
      echo "ERROR: [$host] docker compose up failed" >&2
      failed="$failed $host"
      continue
    fi
  fi

  echo "==> [$host] waiting for $service to become healthy (timeout: ${HEALTH_TIMEOUT}s)"
  if [ -n "$daemon_api_key" ]; then
    health_cmd="curl -sf -H 'X-API-Key: ${daemon_api_key}' http://127.0.0.1:${daemon_port}/health"
  else
    health_cmd="curl -sf http://127.0.0.1:${daemon_port}/health"
  fi

  elapsed=0
  timed_out=false
  while ! run_remote_command "$host" "$health_cmd" >/dev/null 2>&1; do
    if [ "$elapsed" -ge "$HEALTH_TIMEOUT" ]; then
      timed_out=true
      break
    fi
    sleep 5
    elapsed=$((elapsed + 5))
  done

  if [ "$timed_out" = "true" ]; then
    echo "  WARNING: [$host] $service did not become healthy within ${HEALTH_TIMEOUT}s — check logs" >&2
  else
    echo "==> [$host] $service healthy (${elapsed}s)"
  fi

  print_remote_container_summary "$host" "sma-ng"

  # Verify the container ended up on the same image that the registry
  # currently advertises as our deploy tag. Catches three deploy bugs in
  # one shot: (1) the pull silently fell back to a cached older layer,
  # (2) the compose recreate kept the previous container, (3) a newer
  # CI build landed between our pull and our verification. Non-fatal so
  # an opaque registry hiccup doesn't fail an otherwise-good deploy.
  if image_ref=$(resolve_image_ref 2>/dev/null) && [ -n "$image_ref" ]; then
    echo "==> [$host] verifying image freshness against $image_ref"
    verify_remote_image_current "$host" "sma-ng" "$image_ref" || true
  else
    echo "  WARNING: [$host] no image ref resolvable — skipping freshness check" >&2
  fi

  echo "==> [$host] done"
done

if [ -n "$failed" ]; then
  echo ""
  echo "ERROR: docker redeploy failed for:$failed" >&2
  exit 1
fi

echo ""
echo "Docker redeploy complete: $DEPLOY_HOSTS"
