#!/usr/bin/env bash
#MISE description="Build sma-ng.yml locally per-host (schema-driven + setup/local.yml overrides) and push to each host's config dir"
#MISE depends=["deploy:check"]
set -euo pipefail

# shellcheck disable=SC1091
source "$(dirname "$0")/../../shared/deploy/lib.sh"

ALL_HOSTS=$(lc deploy hosts "")
if [ -n "${HOSTS:-}" ]; then
  DEPLOY_HOSTS="$HOSTS"
else
  DEPLOY_HOSTS="${HOST:-$ALL_HOSTS}"
fi

if [ -z "$DEPLOY_HOSTS" ]; then
  echo "ERROR: no hosts selected. Set HOST, HOSTS, or deploy.hosts in $LOCAL" >&2
  exit 1
fi

# Prefer the project venv (which has ruamel.yaml + pydantic) over system python.
if [ -x "venv/bin/python3" ]; then
  LOCAL_PY="venv/bin/python3"
else
  LOCAL_PY="python3"
fi

b64enc() { printf '%s' "$1" | base64 | tr -d '\n'; }

STAGING_ROOT="${STAGING_ROOT:-$(pwd)/.deploy-staging}"
mkdir -p "$STAGING_ROOT"

# JSON sections are sourced once per run from setup/local.yml — they don't
# depend on the target host so a single extraction is enough.
services_json=$("$LOCAL_PY" scripts/services-json.py "$LOCAL")
base_overrides_json=$("$LOCAL_PY" scripts/local-section-json.py "$LOCAL" base)
profiles_overrides_json=$("$LOCAL_PY" scripts/local-section-json.py "$LOCAL" profiles)
daemon_overrides_json=$("$LOCAL_PY" scripts/local-section-json.py "$LOCAL" daemon)

# Credential / integration fields are also deploy-wide rather than per-host.
daemon_api_key=$(lc daemon api_key "")
daemon_ffmpeg_dir_global=$(lc daemon ffmpeg_dir "")

failed=""
for host in $DEPLOY_HOSTS; do
  init_host_context "$host"
  # shellcheck disable=SC2154  # cfg/dir/ffmpeg_dir/ssh_opts/ssh_target populated by init_host_context
  daemon_workers=$($cfg workers "")
  # shellcheck disable=SC2154  # ditto — re-declare here so the warning doesn't recur further down
  : "$ffmpeg_dir" "$ssh_target" "$dir" "$ssh_opts"
  daemon_node_name="$host"
  docker_profile=$($cfg docker_profile "")

  daemon_ffmpeg_dir="$daemon_ffmpeg_dir_global"
  [ -z "$daemon_ffmpeg_dir" ] && daemon_ffmpeg_dir="$ffmpeg_dir"

  daemon_db_url=""
  daemon_db_user=""
  daemon_db_pw=""
  daemon_db_name=""

  if [[ "$docker_profile" == *-pg ]]; then
    daemon_db_user=$($cfg db_user "sma")
    daemon_db_pw=$($cfg db_password "")
    daemon_db_name=$($cfg db_name "sma")
  else
    daemon_db_url=$(lc daemon db_url "")
    if [ -z "$daemon_db_url" ]; then
      _db_host=$($cfg db_host "")
      if [ -n "$_db_host" ]; then
        _db_user=$($cfg db_user "sma")
        _db_pw=$($cfg db_password "")
        _db_port=$($cfg db_port "5432")
        _db_name=$($cfg db_name "sma")
        if [ -n "$_db_pw" ]; then
          daemon_db_url="postgresql://${_db_user}:${_db_pw}@${_db_host}:${_db_port}/${_db_name}"
        else
          daemon_db_url="postgresql://${_db_user}@${_db_host}:${_db_port}/${_db_name}"
        fi
      fi
    fi
  fi

  staging="$STAGING_ROOT/$host"
  mkdir -p "$staging/config"

  echo ""
  echo "==> [$host] building config locally in $staging/config"

  cp setup/sma-ng.yml.sample "$staging/config/sma-ng.yml"

  _api_b64=$(b64enc "$daemon_api_key")
  _db_url_b64=$(b64enc "$daemon_db_url")
  _ffmpeg_b64=$(b64enc "$daemon_ffmpeg_dir")
  _node_name_b64=$(b64enc "$daemon_node_name")
  _dbuser_b64=$(b64enc "$daemon_db_user")
  _dbpw_b64=$(b64enc "$daemon_db_pw")
  _dbname_b64=$(b64enc "$daemon_db_name")
  _svc_b64=$(b64enc "$services_json")
  _base_b64=$(b64enc "$base_overrides_json")
  _prof_b64=$(b64enc "$profiles_overrides_json")
  _workers_b64=$(b64enc "$daemon_workers")
  _daemon_b64=$(b64enc "$daemon_overrides_json")

  if ! "$LOCAL_PY" .mise/shared/deploy/lib/stamp_daemon.py \
    "$staging" \
    "$_api_b64" "$_db_url_b64" "$_ffmpeg_b64" "$_node_name_b64" \
    "$_dbuser_b64" "$_dbpw_b64" "$_dbname_b64" \
    "$_svc_b64" "$_base_b64" "$_prof_b64" "$_workers_b64" "$_daemon_b64"; then
    echo "ERROR: [$host] stamp_daemon failed" >&2
    failed="$failed $host"
    continue
  fi

  if [ -n "$daemon_ffmpeg_dir" ]; then
    if ! "$LOCAL_PY" .mise/shared/deploy/lib/stamp_ffmpeg.py \
      "$staging" "$daemon_ffmpeg_dir" "false"; then
      echo "ERROR: [$host] stamp_ffmpeg failed" >&2
      failed="$failed $host"
      continue
    fi
  fi

  # Push the generated file. The remote config dir already exists from a
  # previous deploy:setup; we just overwrite sma-ng.yml in place.
  echo "==> [$host] pushing config/sma-ng.yml to $ssh_target:$dir/config/"
  # shellcheck disable=SC2086,SC2154  # ssh_opts must word-split; ssh_target/dir set by init_host_context
  if ! rsync -az -e "ssh $ssh_opts" \
    "$staging/config/sma-ng.yml" \
    "$ssh_target:$dir/config/sma-ng.yml"; then
    echo "ERROR: [$host] rsync of sma-ng.yml failed" >&2
    failed="$failed $host"
    continue
  fi

  chown_remote_path_to_ssh_user "$host" "$dir/config/sma-ng.yml"

  echo "==> [$host] config delivered"
done

if [ -n "$failed" ]; then
  echo ""
  echo "ERROR: deploy:config failed for:$failed" >&2
  exit 1
fi

echo ""
echo "Config build + push complete: $DEPLOY_HOSTS"
echo "Staging dir: $STAGING_ROOT"
