#!/usr/bin/env bash
#MISE description="Pull latest Docker image and recreate SMA containers on all DEPLOY_HOSTS"
#MISE depends=["deploy:check"]
set -euo pipefail

LOCAL="setup/.local.ini"
CFG="scripts/local-config.sh"
ALL_HOSTS=$("$CFG" "$LOCAL" deploy DEPLOY_HOSTS "")
DEPLOY_HOSTS="${HOST:-$ALL_HOSTS}"

HEALTH_TIMEOUT=${HEALTH_TIMEOUT:-120}

mk_ssh_opts() {
  local port="$1" key="$2"
  SSH_OPTS=(-p "$port" -o BatchMode=yes -o StrictHostKeyChecking=accept-new)
  [ -n "$key" ] && SSH_OPTS+=(-i "$(eval echo "$key")")
}

failed=""
for host in $DEPLOY_HOSTS; do
  cfg="$CFG $LOCAL $host"
  dir=$($cfg DEPLOY_DIR ~/sma)
  port=$($cfg SSH_PORT 22)
  key=$($cfg SSH_KEY "")
  use_sudo=$($cfg DEPLOY_USE_SUDO "false")
  profile=$($cfg DOCKER_PROFILE "")
  compose_dir=$($cfg DOCKER_COMPOSE_DIR "$dir/docker")
  daemon_port=$($cfg DAEMON_PORT 8585)
  daemon_api_key=$($cfg DAEMON_API_KEY "")

  if [ -z "$profile" ]; then
    echo "ERROR: [$host] DOCKER_PROFILE is not set in $LOCAL — add it to [deploy] or the host section" >&2
    failed="$failed $host"
    continue
  fi

  pg_password=$($cfg POSTGRES_PASSWORD "")
  pg_user=$($cfg POSTGRES_USER "sma")
  pg_db=$($cfg POSTGRES_DB "sma")
  pg_host=$($cfg POSTGRES_HOST "sma-pgsql")
  sma_db_url=$($cfg SMA_DAEMON_DB_URL "")

  mk_ssh_opts "$port" "$key"

  # Build the docker compose command prefix, injecting PG credentials when set.
  # For sudo, use `sudo env KEY=val` so the vars are visible to docker compose.
  # SMA_DAEMON_DB_URL is only injected when explicitly set in .local.ini —
  # otherwise daemon.json db_url takes effect inside the container.
  pg_env_str=""
  if [ -n "$pg_password" ]; then
    pw_q=$(printf '%q' "$pg_password")
    user_q=$(printf '%q' "$pg_user")
    db_q=$(printf '%q' "$pg_db")
    host_q=$(printf '%q' "$pg_host")
    pg_env_str="POSTGRES_PASSWORD=${pw_q} POSTGRES_USER=${user_q} POSTGRES_DB=${db_q} POSTGRES_HOST=${host_q} "
  fi
  if [ -n "$sma_db_url" ]; then
    db_url_q=$(printf '%q' "$sma_db_url")
    pg_env_str="${pg_env_str}SMA_DAEMON_DB_URL=${db_url_q} "
  fi

  if [ "$use_sudo" = "true" ] && [ -n "$pg_env_str" ]; then
    compose_cmd="sudo env ${pg_env_str}docker compose"
  elif [ "$use_sudo" = "true" ]; then
    compose_cmd="sudo docker compose"
  else
    compose_cmd="${pg_env_str}docker compose"
  fi

  sudo_prefix=""
  [ "$use_sudo" = "true" ] && sudo_prefix="sudo "

  service="sma-${profile}"

  echo ""
  echo "==> [$host] upgrading $service (profile: $profile)"

  # Pull the latest image for this profile
  echo "==> [$host] pulling latest image"
  if ! ssh "${SSH_OPTS[@]}" "$host" "cd $compose_dir && ${compose_cmd} --profile $profile pull"; then
    echo "ERROR: [$host] docker compose pull failed" >&2
    failed="$failed $host"
    continue
  fi

  # Recreate only the SMA service — leave postgres untouched
  echo "==> [$host] recreating $service"
  if ! ssh "${SSH_OPTS[@]}" "$host" "cd $compose_dir && ${compose_cmd} --profile $profile up -d --force-recreate --no-deps $service"; then
    echo "ERROR: [$host] docker compose up failed" >&2
    failed="$failed $host"
    continue
  fi

  # Poll the health endpoint until the daemon is ready
  echo "==> [$host] waiting for $service to become healthy (timeout: ${HEALTH_TIMEOUT}s)"
  if [ -n "$daemon_api_key" ]; then
    health_cmd="curl -sf -H 'X-API-Key: ${daemon_api_key}' http://127.0.0.1:${daemon_port}/health"
  else
    health_cmd="curl -sf http://127.0.0.1:${daemon_port}/health"
  fi

  elapsed=0
  timed_out=false
  # shellcheck disable=SC2029
  while ! ssh "${SSH_OPTS[@]}" "$host" "$health_cmd" >/dev/null 2>&1; do
    if [ "$elapsed" -ge "$HEALTH_TIMEOUT" ]; then
      timed_out=true
      break
    fi
    sleep 5
    elapsed=$((elapsed + 5))
  done

  if [ "$timed_out" = "true" ]; then
    echo "  WARNING: [$host] $service did not become healthy within ${HEALTH_TIMEOUT}s — check logs" >&2
  else
    echo "==> [$host] $service healthy (${elapsed}s)"
  fi

  # Print running container summary
  # shellcheck disable=SC2029
  ssh "${SSH_OPTS[@]}" "$host" \
    "${sudo_prefix}docker ps --filter name=${service} --format 'table {{.Names}}\t{{.Image}}\t{{.Status}}'"

  echo "==> [$host] done"
done

if [ -n "$failed" ]; then
  echo ""
  echo "ERROR: docker upgrade failed for:$failed" >&2
  exit 1
fi

echo ""
echo "Docker upgrade complete: $DEPLOY_HOSTS"
