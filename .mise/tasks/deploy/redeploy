#!/usr/bin/env bash
#MISE description="Build/push current code, then redeploy production Docker hosts"
#MISE aliases=["deploy:prod"]
#MISE depends=["deploy:check"]
set -euo pipefail

# shellcheck disable=SC1091
# lib.sh is sourced relative to this script's directory at runtime.
source "$(dirname "$0")/../../shared/deploy/lib.sh"

selected_hosts() {
  if [ -n "${HOSTS:-}" ]; then
    printf '%s\n' "$HOSTS"
  elif [ -n "${HOST:-}" ]; then
    printf '%s\n' "$HOST"
  else
    lc deploy hosts ""
  fi
}

image_from_config() {
  local configured_image configured_tag gh_user tag
  configured_image=$(lc deploy image "")
  configured_tag=$(lc deploy image_tag "")
  if [ -n "$configured_image" ]; then
    if [ -z "${IMAGE_TAG:-}" ] &&
      [[ "$configured_image" == *:* ]] &&
      [[ "${configured_image##*:}" != */* ]]; then
      printf '%s\n' "$configured_image"
      return
    fi
    tag="${IMAGE_TAG:-${configured_tag:-latest}}"
    printf '%s:%s\n' "$configured_image" "$tag"
    return
  fi

  gh_user=$(lc deploy gh_user "")
  if [ -z "$gh_user" ] && command -v gh >/dev/null 2>&1; then
    gh_user=$(gh api user --jq '.login' 2>/dev/null || true)
  fi
  if [ -z "$gh_user" ]; then
    echo "ERROR: set IMAGE=ghcr.io/<owner>/sma-ng:<tag> or deploy.gh_user in $LOCAL" >&2
    return 1
  fi

  tag="${IMAGE_TAG:-${configured_tag:-latest}}"
  printf 'ghcr.io/%s/sma-ng:%s\n' "$gh_user" "$tag"
}

split_image_ref() {
  local image_ref="$1"
  if [[ "$image_ref" == *@sha256:* ]]; then
    echo "ERROR: digest image refs are not supported by deploy:redeploy; use a tag" >&2
    return 1
  fi
  if [[ "$image_ref" != *:* ]] || [[ "${image_ref##*:}" == */* ]]; then
    DEPLOY_IMAGE="$image_ref"
    DEPLOY_IMAGE_TAG="latest"
  else
    DEPLOY_IMAGE="${image_ref%:*}"
    DEPLOY_IMAGE_TAG="${image_ref##*:}"
  fi
}

DEPLOY_HOSTS=$(selected_hosts)
if [ -z "$DEPLOY_HOSTS" ]; then
  echo "ERROR: no hosts selected. Set HOST, HOSTS, or deploy.hosts in $LOCAL" >&2
  exit 1
fi

IMAGE="${IMAGE:-$(image_from_config)}"
split_image_ref "$IMAGE"

BUILD_IMAGE="${BUILD_IMAGE:-true}"
ROLL_CONFIG="${ROLL_CONFIG:-false}"
PLATFORM="${PLATFORM:-linux/amd64}"

echo "Redeploy targets: $DEPLOY_HOSTS"
echo "Image: ${DEPLOY_IMAGE}:${DEPLOY_IMAGE_TAG}"

if [ "$BUILD_IMAGE" = "true" ]; then
  echo ""
  echo "==> Building and pushing image (${PLATFORM})"
  IMAGE="${DEPLOY_IMAGE}:${DEPLOY_IMAGE_TAG}" PLATFORM="$PLATFORM" mise run build:push
else
  echo ""
  echo "==> Skipping image build (BUILD_IMAGE=false)"
fi

if [ "$ROLL_CONFIG" = "true" ]; then
  echo ""
  echo "==> Rolling config before redeploy"
  for host in $DEPLOY_HOSTS; do
    HOST="$host" mise run config:roll
  done
else
  echo ""
  echo "==> Skipping config roll (set ROLL_CONFIG=true to include it)"
fi

failed=""
for host in $DEPLOY_HOSTS; do
  echo ""
  echo "==> [$host] redeploying ${DEPLOY_IMAGE}:${DEPLOY_IMAGE_TAG}"
  if ! SMA_IMAGE="$DEPLOY_IMAGE" SMA_IMAGE_TAG="$DEPLOY_IMAGE_TAG" HOST="$host" mise run deploy:docker; then
    failed="$failed $host"
  fi
done

if [ -n "$failed" ]; then
  echo ""
  echo "ERROR: redeploy failed for:$failed" >&2
  exit 1
fi

echo ""
echo "Redeploy complete: $DEPLOY_HOSTS"
