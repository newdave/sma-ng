#!/usr/bin/env bash
#MISE description="Sync the local .mise/ deploy control plane to all DEPLOY_HOSTS"
#MISE depends=["deploy:check"]
set -euo pipefail

# shellcheck disable=SC1091
# lib.sh is sourced relative to this script's directory at runtime.
source "$(dirname "$0")/../../shared/deploy/lib.sh"

ALL_HOSTS=$(lc deploy hosts "")
DEPLOY_HOSTS="${HOST:-$ALL_HOSTS}"

failed=""
for host in $DEPLOY_HOSTS; do
  init_host_context "$host"

  echo ""
  # shellcheck disable=SC2154  # dir is set by init_host_context above.
  echo "==> [$host] syncing .mise control plane to $dir/.mise"
  run_remote_command "$host" "mkdir -p $dir/.mise" || { failed="$failed $host"; continue; }

  # shellcheck disable=SC2086,SC2154  # ssh_opts, ssh_target, and dir are set by init_host_context above.
  rsync -az --delete \
    -e "ssh $ssh_opts" \
    .mise/ "$ssh_target:$dir/.mise/" || { failed="$failed $host"; continue; }

  chown_remote_path_to_ssh_user "$host" "$dir/.mise"
done

if [ -n "$failed" ]; then
  echo ""
  echo "ERROR: .mise sync failed for:$failed" >&2
  exit 1
fi

echo ""
echo ".mise sync complete: $DEPLOY_HOSTS"
