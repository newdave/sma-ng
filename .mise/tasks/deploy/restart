#!/usr/bin/env bash
#MISE description="Gracefully shut down sma-daemon on all deploy.hosts via webhook, then restart its Docker container"
#MISE depends=["deploy:mise"]
set -euo pipefail

# shellcheck disable=SC1091
# lib.sh is sourced relative to this script's directory at runtime.
source "$(dirname "$0")/../../shared/deploy/lib.sh"

DEPLOY_HOSTS=$(lc deploy hosts "")
SHUTDOWN_TIMEOUT=${SHUTDOWN_TIMEOUT:-120}  # seconds to wait for graceful shutdown
daemon_api_key=$(lc daemon api_key "")

failed=""
for host in $DEPLOY_HOSTS; do
  init_docker_host_context "$host"
  # shellcheck disable=SC2154  # cfg/profile/ssh_opts/ssh_target/sudo_prefix populated by init_docker_host_context above
  daemon_port=$($cfg daemon_port 8585)

  if [ -z "$profile" ]; then
    echo "ERROR: [$host] docker_profile is not set in $LOCAL — add it to deploy: or the host: entry" >&2
    failed="$failed $host"
    continue
  fi

  echo "==> [$host] sending shutdown webhook"

  # Build the remote curl commands locally so all variables expand here,
  # then pass the fully-formed strings to ssh (intentional client-side expansion).
  daemon_url="http://127.0.0.1:${daemon_port}"
  if [ -n "$daemon_api_key" ]; then
    remote_shutdown="curl -sf -X POST ${daemon_url}/shutdown -H 'X-API-Key: ${daemon_api_key}'"
    remote_health="curl -sf ${daemon_url}/health"
  else
    remote_shutdown="curl -sf -X POST ${daemon_url}/shutdown"
    remote_health="curl -sf ${daemon_url}/health"
  fi

  # shellcheck disable=SC2086,SC2029,SC2154  # ssh_opts/ssh_target are populated by init_docker_host_context above; ssh_opts must word-split for ssh
  if ! ssh $ssh_opts "$ssh_target" "$remote_shutdown" > /dev/null 2>&1; then
    echo "  [$host] daemon not responding to shutdown webhook (already stopped or not yet started), proceeding"
  else
    echo "==> [$host] waiting for sma-daemon to stop (timeout: ${SHUTDOWN_TIMEOUT}s)"
    # Poll /health until the daemon stops responding
    elapsed=0
    # shellcheck disable=SC2086,SC2029,SC2154  # ssh_opts/ssh_target are populated by init_docker_host_context above; ssh_opts must word-split for ssh
    while ssh $ssh_opts "$ssh_target" "$remote_health" > /dev/null 2>&1; do
      if [ "$elapsed" -ge "$SHUTDOWN_TIMEOUT" ]; then
        echo "  WARNING: [$host] daemon did not stop within ${SHUTDOWN_TIMEOUT}s, forcing restart anyway"
        break
      fi
      sleep 2
      elapsed=$((elapsed + 2))
    done
    echo "==> [$host] daemon stopped (${elapsed}s)"
  fi

  echo "==> [$host] restarting sma-daemon container (profile: $profile)"
  if ! run_remote_compose "$host" "--profile $profile restart sma"; then
    echo "ERROR: [$host] docker compose restart sma failed" >&2
    failed="$failed $host"
    continue
  fi
  echo "==> [$host] sma-daemon restarted"
done

if [ -n "$failed" ]; then
  echo ""
  echo "ERROR: restart failed for:$failed" >&2
  exit 1
fi

echo ""
echo "sma-daemon restarted on: $DEPLOY_HOSTS"
