#!/usr/bin/env bash
#MISE description="Prepare remote hosts: generate SSH key, update ~/.ssh/config, copy key, install apt deps, create deploy_dir, install systemd unit, verify ffmpeg"
#MISE depends=["deploy:check"]
set -euo pipefail

# shellcheck source=../../shared/deploy/lib.sh
# shellcheck disable=SC1091
source "$(dirname "$0")/../../shared/deploy/lib.sh"
ALL_HOSTS=$(lc deploy hosts "")

# If HOST is set (e.g. called as a recovery step from deploy:host), scope to
# that host only so we don't re-probe or re-prompt for unrelated hosts.
DEPLOY_HOSTS="${HOST:-$ALL_HOSTS}"

# ── 1. ensure SSH key exists ────────────────────────────────────────────────
key=$(lc deploy ssh_key "")
if [ -n "$key" ]; then
    keyfile=$(eval echo "$key")
    if [ ! -f "$keyfile" ]; then
        echo "==> SSH key $keyfile not found — generating ed25519 key"
        ssh-keygen -t ed25519 -f "$keyfile" -N "" -C "sma-deploy"
        echo "==> Generated $keyfile"
    else
        echo "==> SSH key $keyfile already exists"
    fi
else
    echo "==> No ssh_key configured, skipping key setup"
fi

# ── 2. add/update Host blocks in ~/.ssh/config ──────────────────────────────
sshcfg=~/.ssh/config
mkdir -p ~/.ssh && chmod 700 ~/.ssh
touch "$sshcfg" && chmod 600 "$sshcfg"

for host in $DEPLOY_HOSTS; do
    cfg="$CFG $LOCAL $host"
    port=$($cfg ssh_port 22)
    key=$($cfg ssh_key "")
    [ -z "$key" ] && continue
    keyfile=$(eval echo "$key")
    [ -f "$keyfile" ] || continue

    remote_user=$($cfg user "$(whoami)")
    remote_address=$($cfg address "")
    ssh_target="${remote_user}@${remote_address}"
    hostname="$remote_address"
    user="$remote_user"
    marker="# sma-deploy: $host"

    if grep -qsF "$marker" "$sshcfg"; then
        echo "==> [$host] ~/.ssh/config entry already present, skipping"
    else
        echo "==> [$host] adding Host block to $sshcfg"
        {
            printf '\n%s\n'           "$marker"
            printf 'Host %s\n'       "$hostname"
            [ -n "$user" ]         && printf '    User %s\n'        "$user"
            [ "$port" != "22" ]    && printf '    Port %s\n'        "$port"
            printf '    IdentityFile %s\n' "$keyfile"
            printf '    IdentitiesOnly yes\n'
        } >> "$sshcfg"
    fi
done

# ── 3. copy SSH key to each host ────────────────────────────────────────────
for host in $DEPLOY_HOSTS; do
    cfg="$CFG $LOCAL $host"
    port=$($cfg ssh_port 22)
    key=$($cfg ssh_key "")
    [ -z "$key" ] && continue
    keyfile=$(eval echo "$key")
    pubkey="$keyfile.pub"
    [ -f "$pubkey" ] || continue

    remote_user=$($cfg user "$(whoami)")
    remote_address=$($cfg address "")
    ssh_target="${remote_user}@${remote_address}"

    echo "==> [$host] copying SSH key (password prompt may follow)"
    ssh-copy-id -i "$pubkey" -p "$port" "$ssh_target"
done

# ── 4. install apt prerequisites on each host ──────────────────────────────
APT_PACKAGES="build-essential python3-dev python3-venv"
for host in $DEPLOY_HOSTS; do
    cfg="$CFG $LOCAL $host"
    port=$($cfg ssh_port 22)
    key=$($cfg ssh_key "")
    use_sudo=$($cfg use_sudo "false")

    remote_user=$($cfg user "$(whoami)")
    remote_address=$($cfg address "")
    ssh_target="${remote_user}@${remote_address}"

    mk_ssh_opts "$port" "$key"

    sudo_prefix=""
    [ "$use_sudo" = "true" ] && sudo_prefix="sudo "

    echo "==> [$host] installing apt prerequisites: $APT_PACKAGES"
    # shellcheck disable=SC2029,SC2087  # sudo_prefix expands client-side; the heredoc body stays literal until the remote shell runs it.
  ssh "${SSH_OPTS[@]}" "$ssh_target" "${sudo_prefix}bash -s" <<'REMOTE'
    if ! command -v apt-get >/dev/null 2>&1; then
      echo '  SKIP: apt-get not found'
      exit 0
    fi
    apt-get install -y build-essential python3-dev python3-venv
REMOTE
done

# ── 5. install Docker via the Docker apt repo on each host ──────────────────
for host in $DEPLOY_HOSTS; do
    cfg="$CFG $LOCAL $host"
    port=$($cfg ssh_port 22)
    key=$($cfg ssh_key "")
    use_sudo=$($cfg use_sudo "false")

    remote_user=$($cfg user "$(whoami)")
    remote_address=$($cfg address "")
    ssh_target="${remote_user}@${remote_address}"

    mk_ssh_opts "$port" "$key"

    sudo_prefix=""
    [ "$use_sudo" = "true" ] && sudo_prefix="sudo "

    echo "==> [$host] installing Docker via apt"
    # shellcheck disable=SC2029,SC2087  # sudo_prefix expands client-side; the heredoc body stays literal until the remote shell runs it.
    ssh "${SSH_OPTS[@]}" "$ssh_target" "${sudo_prefix}bash -s" <<'REMOTE'
    if command -v docker >/dev/null 2>&1; then
      echo '  SKIP: docker already installed'
      exit 0
    fi
    if ! command -v apt-get >/dev/null 2>&1; then
      echo '  SKIP: apt-get not found'
      exit 0
    fi
    apt-get install -y ca-certificates curl
    install -m 0755 -d /etc/apt/keyrings
    . /etc/os-release
    curl -fsSL "https://download.docker.com/linux/${ID}/gpg" -o /etc/apt/keyrings/docker.asc
    chmod a+r /etc/apt/keyrings/docker.asc
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/${ID} ${VERSION_CODENAME:-${UBUNTU_CODENAME}} stable" \
      | tee /etc/apt/sources.list.d/docker.list > /dev/null
    apt-get update
    apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
REMOTE
done

# ── 6. create deploy_dir on each host ──────────────────────────────────────
for host in $DEPLOY_HOSTS; do
    cfg="$CFG $LOCAL $host"
    dir=$($cfg deploy_dir ~/sma)
    port=$($cfg ssh_port 22)
    key=$($cfg ssh_key "")
    use_sudo=$($cfg use_sudo "false")

    remote_user=$($cfg user "$(whoami)")
    remote_address=$($cfg address "")
    ssh_target="${remote_user}@${remote_address}"

    mk_ssh_opts "$port" "$key"

    echo "==> [$host] ensuring $dir exists"
    if [ "$use_sudo" = "true" ] && [ -n "$remote_user" ]; then
        # shellcheck disable=SC2029  # dir/remote_user intentionally expand client-side before the remote shell runs.
        ssh "${SSH_OPTS[@]}" "$ssh_target" "sudo mkdir -p $dir && sudo chown $remote_user: $dir"
    else
        # shellcheck disable=SC2029  # dir intentionally expands client-side before the remote shell runs.
        ssh "${SSH_OPTS[@]}" "$ssh_target" "mkdir -p $dir"
    fi
done

# ── 7. sync code and install systemd service on each host ─────────────────
for host in $DEPLOY_HOSTS; do
    cfg="$CFG $LOCAL $host"
    dir=$($cfg deploy_dir ~/sma)
    port=$($cfg ssh_port 22)
    key=$($cfg ssh_key "")
    rsync_extra=$($cfg rsync_extra "")

    remote_user=$($cfg user "$(whoami)")
    remote_address=$($cfg address "")
    ssh_target="${remote_user}@${remote_address}"

    mk_ssh_opts "$port" "$key"

    echo "==> [$host] syncing code to $dir"
    # shellcheck disable=SC2086
    rsync -az --delete \
    -e "ssh ${SSH_OPTS[*]}" \
    --exclude='.git/' \
    --exclude='venv/' \
    --exclude='config/' \
    --exclude='logs/' \
    --exclude='__pycache__/' \
    --exclude='*.pyc' \
    --exclude='.local' \
    --exclude='*.egg-info/' \
    $rsync_extra \
    . "$ssh_target:$dir"

    install_dir=$($cfg sma_install_dir "/opt/sma")
    echo "==> [$host] installing sma-daemon service (user: $remote_user, dir: $install_dir)"
    # shellcheck disable=SC2029,SC2087  # dir/remote_user/install_dir expand client-side; heredoc body stays literal until the remote shell runs it.
    ssh "${SSH_OPTS[@]}" "$ssh_target" 'bash -s' "$dir" "$remote_user" "$install_dir" <<'REMOTE'
      set -euo pipefail
      dir="$1"
      service_user="$2"
      install_dir="$3"
      cd "$dir"

      sudo mkdir -p "${install_dir}/config" "${install_dir}/logs"
      sudo chown -R "$service_user": "${install_dir}/config" "${install_dir}/logs"

      if [ ! -f "${install_dir}/config/daemon.env" ]; then
        sudo install -o "$service_user" -m 640 setup/daemon.env.sample "${install_dir}/config/daemon.env"
      fi

      sudo chmod 755 setup/sma-daemon-start.sh
      sed "s/^User=.*/User=${service_user}/; s/^Group=.*/Group=${service_user}/; s|/opt/sma|${install_dir}|g" setup/sma-daemon.service \
        | sudo tee /etc/systemd/system/sma-daemon.service > /dev/null
      sudo systemctl daemon-reload
#      sudo systemctl enable --now sma-daemon  # (removed: do not enable/start by default)
REMOTE
done
