#!/usr/bin/env bash
#MISE description="Sync code to all deploy.hosts and install dependencies"
#MISE depends=["deploy:mise"]
set -euo pipefail

# shellcheck disable=SC1091
# lib.sh is sourced relative to this script's directory at runtime.
source "$(dirname "$0")/../../shared/deploy/lib.sh"

DEPLOY_HOSTS=$(lc deploy hosts "")

failed=""
for host in $DEPLOY_HOSTS; do
  cfg="$CFG $LOCAL $host"
  init_host_context "$host"
  branch=$($cfg deploy_branch "")
  rsync_extra=$($cfg rsync_extra "")

  _run_install() {
    install_remote_base_deps "$host"
  }

  echo ""
  sync_codebase_to_host "$host" "$rsync_extra" || { failed="$failed $host"; continue; }

  if [ -n "$branch" ]; then
    echo "==> [$host] checking out $branch"
    run_remote_command "$host" "git checkout $branch"
  fi

  echo "==> [$host] installing dependencies"

  ensure_venv_ready "$host" || { failed="$failed $host"; continue; }

  run_with_prereq_retry "$host" "pre-req missing — running deploy:setup then retrying" "install base dependencies" _run_install || {
    failed="$failed $host"
    continue
  }
done

if [ -n "$failed" ]; then
  echo ""
  echo "ERROR: deployment failed for:$failed" >&2
  exit 1
fi

echo ""
echo "Deployment complete: $DEPLOY_HOSTS"
echo "Run 'mise run deploy:restart' to restart sma-daemon on all hosts."
