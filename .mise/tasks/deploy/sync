#!/usr/bin/env bash
#MISE description="Sync code to all DEPLOY_HOSTS, install dependencies, and reload systemd"
#MISE depends=["deploy:mise"]
set -euo pipefail

# shellcheck disable=SC1091
# lib.sh is sourced relative to this script's directory at runtime.
source "$(dirname "$0")/../../shared/deploy/lib.sh"

DEPLOY_HOSTS=$("$CFG" "$LOCAL" deploy DEPLOY_HOSTS "")

failed=""
for host in $DEPLOY_HOSTS; do
  cfg="$CFG $LOCAL $host"
  init_host_context "$host"
  branch=$($cfg DEPLOY_BRANCH "")
  rsync_extra=$($cfg RSYNC_EXTRA "")
  remote_user_for_host=$(echo "$host" | cut -s -d@ -f1)
  remote_user_for_host="${remote_user_for_host:-$(whoami)}"
  deploy_dir=$($cfg DEPLOY_DIR ~/sma)

  _run_install() {
    install_remote_base_deps "$host"
  }

  echo ""
  sync_codebase_to_host "$host" "$rsync_extra" || { failed="$failed $host"; continue; }

  if [ -n "$branch" ]; then
    echo "==> [$host] checking out $branch"
    run_remote_command "$host" "git checkout $branch"
  fi

  echo "==> [$host] installing dependencies"

  ensure_venv_ready "$host" || { failed="$failed $host"; continue; }

  run_with_prereq_retry "$host" "pre-req missing — running deploy:setup then retrying" "install base dependencies" _run_install || {
    failed="$failed $host"
    continue
  }

  echo "==> [$host] updating systemd unit user to $remote_user_for_host"
  run_remote_command "$host" "
    if [ -f /etc/systemd/system/sma-daemon.service ]; then
      sed 's/^User=.*/User=$remote_user_for_host/; s/^Group=.*/Group=$remote_user_for_host/' \
        $deploy_dir/setup/sma-daemon.service \
        | sudo tee /etc/systemd/system/sma-daemon.service > /dev/null
    fi
  " || { failed="$failed $host"; continue; }

  echo "==> [$host] reloading systemd unit"
  run_remote_command "$host" "sudo systemctl daemon-reload" || { failed="$failed $host"; continue; }
done

if [ -n "$failed" ]; then
  echo ""
  echo "ERROR: deployment failed for:$failed" >&2
  exit 1
fi

echo ""
echo "Deployment complete: $DEPLOY_HOSTS"
echo "Run 'mise run deploy:restart' to restart sma-daemon on all hosts."
