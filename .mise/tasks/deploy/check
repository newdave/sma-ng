#!/usr/bin/env bash
#MISE description="Verify setup/.local.yml exists and DEPLOY_HOSTS is set"
set -euo pipefail

LOCAL="setup/.local.yml"
if [ ! -f "$LOCAL" ]; then
  echo "ERROR: $LOCAL not found. Copy setup/.local.yml.sample to setup/.local.yml and configure it." >&2
  exit 1
fi

DEPLOY_HOSTS=$(python3 scripts/local-config.py "$LOCAL" deploy hosts "")
if [ -z "$DEPLOY_HOSTS" ]; then
  echo "ERROR: DEPLOY_HOSTS is not set in the [deploy] section of $LOCAL." >&2
  exit 1
fi

echo "Deployment targets: $DEPLOY_HOSTS"
