#!/usr/bin/env bash
#MISE description="Build and push a Docker image via buildx"
set -euo pipefail

# shellcheck source=../../shared/docker/env.sh
# shellcheck disable=SC1091  # path declared above; shellcheck requires -x to follow sourced files
source "${MISE_PROJECT_ROOT}/.mise/shared/docker/env.sh"

if [ -z "${IMAGE:-}" ]; then
    echo "Error: IMAGE is required (e.g. IMAGE=ghcr.io/owner/sma-ng:latest mise run build:push)" >&2
    exit 1
fi

PLATFORM="${PLATFORM:-linux/amd64,linux/arm64}"
echo "Building and pushing image: $IMAGE (FFmpeg ${FFMPEG_VERSION})..."
echo "Platform: ${PLATFORM}"
docker buildx build \
    --file docker/Dockerfile \
    --target runtime \
    --platform "${PLATFORM}" \
    --build-arg FFMPEG_VERSION="${FFMPEG_VERSION}" \
    --tag "$IMAGE" \
    --push \
    .
echo "Pushed: $IMAGE"
