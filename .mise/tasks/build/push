#!/usr/bin/env bash
#MISE description="Build and push a multi-platform image (linux/amd64 + linux/arm64) via buildx (IMAGE=ghcr.io/owner/sma-ng:latest to override)"
set -euo pipefail

# shellcheck source=../../shared/docker/env.sh
# shellcheck disable=SC1091  # path declared above; shellcheck requires -x to follow sourced files
source "${MISE_PROJECT_ROOT}/.mise/shared/docker/env.sh"

if [ -z "${IMAGE:-}" ]; then
    echo "Error: IMAGE is required (e.g. IMAGE=ghcr.io/owner/sma-ng:latest mise run build:push)" >&2
    exit 1
fi

echo "Building and pushing multi-platform image: $IMAGE (FFmpeg ${FFMPEG_VERSION})..."
docker buildx build \
    --file docker/Dockerfile \
    --target runtime \
    --platform linux/amd64,linux/arm64 \
    --build-arg FFMPEG_VERSION="${FFMPEG_VERSION}" \
    --tag "$IMAGE" \
    --push \
    .
echo "Pushed: $IMAGE"
