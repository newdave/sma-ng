#!/usr/bin/env bash
#MISE description="Run a mise task on all DEPLOY_HOSTS without syncing (REMOTE_TASK=test mise run remote:mise)"
#MISE depends=["deploy:check"]
set -euo pipefail

# shellcheck disable=SC1091
# lib.sh is sourced relative to this script's directory at runtime.
source "$(dirname "$0")/../../shared/deploy/lib.sh"

DEPLOY_HOSTS=$("$CFG" "$LOCAL" deploy DEPLOY_HOSTS "")

failed=""
auto_create_venv=false
for host in $DEPLOY_HOSTS; do
    init_host_context "$host"
    remote_task="${REMOTE_TASK:-$($cfg REMOTE_TASK setup:deps)}"

    _run_task() {
        run_remote_mise_task "$host" "$remote_task"
    }

    maybe_prepare_venv=true
    [ "$remote_task" = "setup:venv" ] && maybe_prepare_venv=false

    if [ "$maybe_prepare_venv" = "true" ] && [ "$auto_create_venv" = "true" ]; then
        ensure_venv_ready "$host" || { failed="$failed $host"; continue; }
    fi

    echo "==> [$host] mise run $remote_task"

    run_with_prereq_retry "$host" "pre-req missing while running mise task $remote_task — running deploy:setup then retrying" "" _run_task || failed="$failed $host"
done

if [ -n "$failed" ]; then
    echo "ERROR: remote task failed for:$failed" >&2
    exit 1
fi
