#!/usr/bin/env bash
#MISE description="Build and push a multi-platform image (linux/amd64 + linux/arm64) via buildx (IMAGE=ghcr.io/owner/sma-ng:latest to override)"
set -euo pipefail

if [ -z "${IMAGE:-}" ]; then
    echo "Error: IMAGE is required (e.g. IMAGE=ghcr.io/owner/sma-ng:latest mise run docker:push)" >&2
    exit 1
fi

FFMPEG_VERSION="${FFMPEG_VERSION:-8.1}"
echo "Building and pushing multi-platform image: $IMAGE (FFmpeg ${FFMPEG_VERSION})..."
docker buildx build \
    --file docker/Dockerfile \
    --target runtime \
    --platform linux/amd64,linux/arm64 \
    --build-arg FFMPEG_VERSION="${FFMPEG_VERSION}" \
    --tag "$IMAGE" \
    --push \
    .
echo "Pushed: $IMAGE"
